rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Vitrine (images publiques) ────────────────────────────────────────
    match /vitrine/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Documents équidés ─────────────────────────────────────────────────
    match /equides/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.token.admin == true || request.auth.token.moniteur == true);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Documents familles ────────────────────────────────────────────────
    match /families/{familyId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Galerie ───────────────────────────────────────────────────────────
    match /galerie/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Bloc par défaut — DENY ALL ────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
