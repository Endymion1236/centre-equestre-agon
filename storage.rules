rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Site vitrine (images publiques) ───────────────────────────────────
    // Affichées aux visiteurs non connectés → lecture publique, écriture admin.
    match /vitrine/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /miniferme/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /galerie/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Documents internes (terrain) ──────────────────────────────────────
    // Fiches équidés et plans de séance : lecture staff (admin/moniteur), écriture admin.
    match /equides/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.token.admin == true || request.auth.token.moniteur == true);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /plans-seance/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.token.admin == true || request.auth.token.moniteur == true);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Photos des cavaliers ──────────────────────────────────────────────
    // Lecture : staff + famille propriétaire. Écriture : staff (la monitrice
    // peut prendre les photos depuis le terrain).
    match /cavaliers/{familyId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.token.admin == true || request.auth.token.moniteur == true || request.auth.uid == familyId);
      allow write: if request.auth != null && (request.auth.token.admin == true || request.auth.token.moniteur == true);
    }

    // ── Documents sensibles ───────────────────────────────────────────────
    // Mandats SEPA scannés (IBAN + signature) : lecture ET écriture admin uniquement.
    match /mandats-sepa/{familyId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Tout le reste : refusé ────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
