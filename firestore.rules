rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && (
        request.auth.token.admin == true
        || request.auth.token.email in ['ceagon@orange.fr', 'ceagon50@gmail.com', 'emmelinelagy@gmail.com']
      );
    }
    function isMoniteur() {
      return isAuth() && request.auth.token.moniteur == true;
    }
    function isStaff() {
      return isAdmin() || isMoniteur();
    }

    // (Fonction isFamilyOwner retirée : toutes les rules utilisent maintenant
    //  directement `resource.data.familyId == request.auth.uid` — plus simple,
    //  plus performant et compatible avec les queries filtrées côté client)

    // ── Familles ──────────────────────────────────────────────────────────
    // Le docId est toujours l'uid du user (pattern : doc(db, "families", user.uid)).
    // On vérifie donc d'abord familyId == auth.uid (le plus fiable, ne dépend
    // pas du contenu). On garde les fallbacks sur des champs internes pour
    // compatibilité avec d'anciens docs (uid, authUid, parentEmail).
    match /families/{familyId} {
      allow read: if isStaff()
        || (isAuth() && familyId == request.auth.uid)
        || (isAuth() && resource.data.uid == request.auth.uid)
        || (isAuth() && resource.data.authUid == request.auth.uid)
        || (isAuth() && resource.data.parentEmail == request.auth.token.email);
      allow create: if isAuth();
      allow update, delete: if isStaff()
        || (isAuth() && familyId == request.auth.uid)
        || (isAuth() && resource.data.uid == request.auth.uid)
        || (isAuth() && resource.data.authUid == request.auth.uid)
        || (isAuth() && resource.data.parentEmail == request.auth.token.email);
    }

    // ── Planning (créneaux) ───────────────────────────────────────────────
    match /creneaux/{docId} {
      allow read: if isAuth();
      allow create, delete: if isStaff();
      // Le staff peut tout modifier. Un cavalier peut UNIQUEMENT modifier les
      // champs `enrolled` et `enrolledCount` (pour s'inscrire/se désinscrire) —
      // pas le prix, pas maxPlaces, pas la date, pas le moniteur, etc.
      allow update: if isStaff()
        || (isAuth()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['enrolled', 'enrolledCount']));
    }

    // ── Paiements / Encaissements ─────────────────────────────────────────
    match /payments/{docId} {
      allow read: if isStaff() || (isAuth() && resource.data.familyId == request.auth.uid);
      // Cavalier peut créer UNIQUEMENT un paiement pending à son nom, non payé
      allow create: if isStaff()
        || (isAuth()
            && request.resource.data.familyId == request.auth.uid
            && request.resource.data.status == "pending"
            && (request.resource.data.paidAmount == 0 || !('paidAmount' in request.resource.data)));
      // Seul le staff peut modifier un paiement (statut, montant encaissé, etc.)
      // Les confirmations CAWL passent par adminDb (bypass rules)
      allow update, delete: if isAdmin();
    }
    match /encaissements/{docId} {
      allow read: if isAdmin();
      // Création : staff (admin + moniteur inscrivant un cavalier au planning).
      // Update/delete : admin uniquement (les corrections sont sensibles).
      // Les écritures automatiques (webhooks CAWL, pay-with-avoir) passent par
      // adminDb et bypassent ces règles.
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ── Équidés ───────────────────────────────────────────────────────────
    match /equides/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Soins équidés ─────────────────────────────────────────────────────
    match /soins/{docId} {
      allow read, write: if isStaff();
    }

    // (Collections 'mouvements' et 'documents-equides' retirées :
    //  seules 'mouvements_registre' et 'documents_equide' sont utilisées)

    // ── Indisponibilités équidés ──────────────────────────────────────────
    match /indisponibilites/{docId} {
      allow read, write: if isStaff();
    }

    // ── SEPA ──────────────────────────────────────────────────────────────
    match /mandats-sepa/{docId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.familyId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /echeances-sepa/{docId} {
      allow read, write: if isAdmin();
    }
    match /remises-sepa/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Rapprochement bancaire ────────────────────────────────────────────
    match /rapprochements/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Challenges / Compétitions ─────────────────────────────────────────
    match /challenges/{docId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // ── Fidélité ──────────────────────────────────────────────────────────
    match /fidelite/{docId} {
      allow read: if isAdmin() || (isAuth() && resource.data.familyId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Push tokens ───────────────────────────────────────────────────────
    // Le docId est le familyId (l'uid). Un user peut lire/écrire son propre
    // token (nécessaire pour le hook usePushNotifications qui vérifie s'il
    // doit se réinscrire aux notifications).
    match /push_tokens/{docId} {
      allow read: if isAdmin() || (isAuth() && docId == request.auth.uid);
      allow create, update: if isAuth() && docId == request.auth.uid;
      allow delete: if isAdmin() || (isAuth() && docId == request.auth.uid);
    }

    // ── Settings (paramètres globaux) ─────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;  // Vitrine, tarifs = publics
      allow write: if isAdmin();
    }

    // ── Périodes de vacances scolaires ────────────────────────────────────
    // Lecture publique (nécessaire pour calcul des réductions côté client,
    // y compris espace-cavalier). Écriture réservée au staff (admin + moniteur).
    match /vacationPeriods/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // ── Progression pédagogique ───────────────────────────────────────────
    match /progressions/{docId} {
      allow read: if isStaff()
        || (isAuth() && docId.matches(request.auth.uid + '_.*'))
        || (isAuth() && resource != null && resource.data.familyId == request.auth.uid);
      allow write: if isStaff();
    }

    // ── Devis ─────────────────────────────────────────────────────────────
    match /devis/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Avoirs ────────────────────────────────────────────────────────────
    // Lecture : staff (moniteurs voient les avoirs actifs d'une famille au planning)
    // Écriture : admin
    match /avoirs/{docId} {
      allow read: if isStaff() || (isAuth() && resource.data.familyId == request.auth.uid);
      // Seul l'admin peut créer/modifier/supprimer un avoir.
      // L'utilisation d'un avoir par un cavalier passe par l'API
      // /api/pay-with-avoir (adminDb bypass)
      allow write: if isAdmin();
    }

    // ── Cartes de séances ─────────────────────────────────────────────────
    // Lecture : staff (moniteurs voient les cartes actives depuis planning/montoir)
    // Écriture : admin
    match /cartes/{docId} {
      allow read: if isStaff() || (isAuth() && resource.data.familyId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Forfaits ──────────────────────────────────────────────────────────
    // Lecture : staff (moniteurs vérifient les forfaits actifs au planning/montoir)
    // Écriture : admin
    match /forfaits/{docId} {
      allow read: if isStaff() || (isAuth() && resource.data.familyId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Activités (catalogue) ─────────────────────────────────────────────
    match /activities/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Moniteurs ─────────────────────────────────────────────────────────
    match /moniteurs/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Thèmes de stage ───────────────────────────────────────────────────
    match /themes-stage/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Management (planning équipe) ──────────────────────────────────────
    match /management/{docId} {
      allow read, write: if isAdmin();
    }
    match /salaries/{docId} {
      allow read, write: if isAdmin();
    }
    match /taches-type/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Satisfaction ──────────────────────────────────────────────────────
    match /satisfaction/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    // ── Réservations (espace cavalier) ────────────────────────────────────
    match /reservations/{docId} {
      allow read: if isStaff()
        || (isAuth() && resource.data.familyId == request.auth.uid)
        || (isAuth() && resource.data.get("sourceFamilyId", "") == request.auth.uid);
      allow create: if isAuth();
      allow update, delete: if isStaff()
        || (isAuth() && resource.data.familyId == request.auth.uid)
        || (isAuth() && resource.data.get("sourceFamilyId", "") == request.auth.uid);
    }

    // ── Email templates ───────────────────────────────────────────────────
    match /email-templates/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Bons cadeaux ──────────────────────────────────────────────────────
    // Admin-only : la vérification de code par les cavaliers passe par
    // l'API route /api/verify-bon-cadeau (admin SDK, bypass rules)
    match /bons-cadeaux/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Bons récupération ─────────────────────────────────────────────────
    match /bonsRecup/{docId} {
      allow read: if isAdmin() || (isAuth() && resource.data.familyId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Paiements FR (collection à migrer vers 'payments' EN) ─────────────
    // ⚠️ Collection legacy utilisée par l'ancien code inscription-annuelle
    // (avant le fix). Accès admin uniquement pour permettre la migration via
    // /api/admin/migrate-paiements-collection. À retirer après migration.
    match /paiements/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Communications (historique emails/notifications) ──────────────────
    match /communications/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Comptabilité (exports, journaux) ──────────────────────────────────
    match /comptabilite/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Templates documents (modèles PDF, email) ──────────────────────────
    match /doc_templates/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Documents équidés (nom alternatif sans tiret) ─────────────────────
    match /documents_equide/{docId} {
      allow read, write: if isStaff();
    }

    // ── Emails de reprise (templates email-reprise) ───────────────────────
    match /emailsReprise/{docId} {
      allow read, write: if isAdmin();
    }

    // (Doublon 'fidelite' retiré — défini une seule fois plus haut)

    // ── Modèles de planning (reprises/horaires) ───────────────────────────
    match /modeles/{docId} {
      allow read, write: if isAdmin();
    }
    match /modeles-planning/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Mouvements registre ───────────────────────────────────────────────
    // Lecture : staff (cavalerie affiche le registre d'un équidé aux moniteurs)
    // Écriture : admin uniquement (registre officiel)
    match /mouvements_registre/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Passages (appel / feuille de présence) ────────────────────────────
    match /passages/{docId} {
      allow read, write: if isStaff();
    }

    // ── Payment declarations (CAWL webhooks) ──────────────────────────────
    match /payment_declarations/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Pédagogie (progressions, niveaux) ────────────────────────────────
    match /pedagogie/{docId} {
      allow read: if isStaff() || (isAuth() && resource.data.familyId == request.auth.uid);
      allow write: if isStaff();
    }

    // ── Rattrapages ───────────────────────────────────────────────────────
    match /rattrapages/{docId} {
      allow read: if isStaff() || (isAuth() && resource.data.familyId == request.auth.uid);
      allow write: if isStaff();
    }

    // ── RDV Pro (vétérinaire, maréchal, dentiste…) ────────────────────────
    match /rdv_pro/{docId} {
      allow read, write: if isStaff();
    }

    // ── Remises (réductions, codes promo) ────────────────────────────────
    match /remises/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Salariés management (planning équipe) ─────────────────────────────
    // Lecture : staff (admins + moniteurs voient l'équipe et leurs propres tâches)
    // Écriture : admin uniquement
    match /salaries-management/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Tâches planifiées (cron, rappels) ─────────────────────────────────
    // Lecture : staff (moniteurs voient leur planning)
    // Écriture : admin OU le moniteur qui toggle 'done' sur sa propre tâche
    match /taches-planifiees/{docId} {
      allow read: if isStaff();
      allow create, delete: if isAdmin();
      // Un moniteur peut mettre à jour UNIQUEMENT si :
      //  - la tâche lui appartient (salarieId correspond à un moniteur identifié par email)
      //  - les seuls champs modifiés sont 'done' et 'updatedAt'
      allow update: if isAdmin()
        || (isMoniteur()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['done', 'updatedAt']));
    }

    // ── Avis satisfaction ─────────────────────────────────────────────────
    match /avis-satisfaction/{docId} {
      allow read: if isAdmin() || (isAuth() && resource.data.familyId == request.auth.uid);
      allow create: if isAuth();
    }

    // ── Liste d'attente ───────────────────────────────────────────────────
    // Lecture : staff (moniteurs voient les inscrits en attente au planning)
    // Écriture : admin (validation/suppression), création par tous utilisateurs auth
    match /waitlist/{docId} {
      allow read: if isStaff() || (isAuth() && resource.data.familyId == request.auth.uid);
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Sessions CAWL (RETURNMAC + metadata checkout) ─────────────────────
    // Collection critique : contient le secret RETURNMAC partagé avec CAWL.
    // Aucun accès côté client — toutes les écritures/lectures passent par
    // adminDb dans les routes /api/cawl/checkout et /api/cawl/status.
    match /cawl_sessions/{docId} {
      allow read, write: if false;
    }

    // ── Confirmations CAWL (verrou anti-doublon webhook/status) ───────────
    // Utilisée par /api/cawl/webhook et /api/cawl/status pour garantir
    // qu'une même confirmation de paiement n'est traitée qu'une seule fois.
    // Aucun accès côté client.
    match /cawl_confirmations/{docId} {
      allow read, write: if false;
    }

    // ── Rate limits (compteurs par user/route) ────────────────────────────
    // Utilisée par lib/rate-limit.ts pour borner l'usage des routes IA.
    // Lecture admin pour audit, écriture bloquée côté client (serveur only).
    match /rate_limits/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Audit log (traçabilité opérations sensibles) ──────────────────────
    // Log append-only pour suppression de comptes, actions destructrices,
    // etc. Lecture admin, écriture serveur-only.
    match /audit_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Audit facturation (traçabilité attribution des numéros) ───────────
    // Lecture admin seulement (pour audit fiscal), écriture bloquée côté
    // client — les entrées sont créées par /api/invoice/next-number (adminDb)
    match /invoice_audit/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Bloc par défaut — DENY ALL ────────────────────────────────────────
    // Toute collection non listée ci-dessus est bloquée
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
